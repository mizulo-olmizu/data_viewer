{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "data_viewer",
  "version": "0.1.0",
  "identifier": "dataviewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "data_viewer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Tauri CLI Plugin Example",
      "args": [
        {
          "short": "i",
          "name": "input",
          "takesValue": true,
          "description": "Path to the CSV file or '-' for standard input"
        },
        {
          "short": "f",
          "name": "file-type",
          "takesValue": true,
          "description": "File type(support csv, json, jsonl, parquet)",
          "possibleValues": ["csv", "json", "jsonl", "parquet"],
          "requires": "input"
        },
        {
          "short": "t",
          "name": "separator",
          "takesValue": true,
          "description": "CSV separator",
          "requires": "input"
        }
      ]
    }
  }
}
